{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "extends": [],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": { "enabled": true },
  "files": {
    "ignore": ["vendor/**", "dist/**", "build/**", "**/*.min.js"]
  },
  "javascript": {
    "globals": ["chrome"],
    "parser": { "unsafeParameterDecoratorsEnabled": false }
  }
}
