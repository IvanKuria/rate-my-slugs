{
  "manifest_version": 3,
  "name": "RateMy Slugs",
  "version": "1.0.0",
  "description": "Shows Rate My Professors ratings for UCSC courses on MyUCSC enrollment pages",
  
  "permissions": ["storage"],
  
  "host_permissions": [
    "https://my.ucsc.edu/*",
    "https://pisa.ucsc.edu/*",
    "https://www.ratemyprofessors.com/*"
  ],
  
  "content_scripts": [
    {
      "matches": [
        "https://my.ucsc.edu/*"
      ],
      "js": ["content/content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://pisa.ucsc.edu/*"
      ],
      "js": ["content/content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  
  "background": {
    "service_worker": "background/background.js"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
